  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: "\u5C0F\u5FC3\uFF0C\u8FD9\u4E9B\u53F2\u83B1\u59C6\u597D\u50CF\u6709\u5F02\u5E38"
