    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: " (\u70B9\u5934\u540C\u610F)"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 1
    text: "(\u524D\u65B9\u521A\u597D\u51FA\u73B0\u4E86\u51E0\u4E2A\u53F2\u83B1\u59C6)"
