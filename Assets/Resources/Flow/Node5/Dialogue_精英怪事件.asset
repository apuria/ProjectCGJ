    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 1
    text: "\uFF08\u53EA\u89C1\u53F2\u83B1\u59C6\u9010\u6E10\u5408\u4F53\uFF0C\u53D8\u6210\u4E86\u4E00\u4E2A\u5927\u578B\u7684\u6218\u573A\u541E\u566C\u8005\uFF0C\u4F53\u5185\u8FD8\u6709\u6E05\u6670\u53EF\u89C1\u7684\u65AD\u80A2\u6B8B\u81C2\uFF09"
