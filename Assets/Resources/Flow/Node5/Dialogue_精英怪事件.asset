  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u8BF4\u5230\u4EC0\u4E48\u6765\u4EC0\u4E48\uFF0C\u5C31\u5F53\u653E\u677E\u6D3B\u52A8\u4E86"
