    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u662F\u554A\uFF0C\u90A3\u79CD\u8F7B\u8F7B\u677E\u677E\u5C31\u80FD\u51FB\u8D25\u7684\u602A\u7269\uFF0C\u6253\u8D77\u6765\u5F88\u89E3\u538B"
