  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u8C22\u8C22\u4F60\u5E74\u8F7B\u4EBA\uFF0C\u8981\u4E0D\u662F\u8FD9\u7FA4\u53EF\u6076\u7684\u9B54\u7269\u5077\u88AD\uFF0C\u6559\u5802\u4E5F\u4E0D\u4F1A\u2026\u2026"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\uFF08\u4F4E\u5934\uFF0C\u7136\u540E\u8E72\u4E0B\uFF09\u5927\u53D4\uFF0C\u6211\u6B64\u884C\u5C31\u662F\u4E3A\u4E86\u51FB\u8D25\u9B54\u738B\uFF0C\u62EF\u6551\u5927\u5BB6"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\uFF08\u770B\u7740\u8E72\u4E0B\u7684\u4F60\uFF09\u4F60\u5C0F\u5B50\u61C2\u4E0D\u61C2\u793C\u8C8C\uFF01"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u7B97\u4E86\uFF0C\u4F60\u4E5F\u7B97\u6551\u6211\u4E00\u547D\uFF0C\u662F\u8981\u8BA8\u4F10\u9B54\u738B\u662F\u5427\uFF0C\u8FD9\u4E2A\u7ED9\u4F60"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 1
    cgImage: {fileID: 21300000, guid: 30e5f8f251b817e42937d16960f12c38, type: 3}
    showDialogueBox: 0
    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u7B97\u4E86\uFF0C\u4F60\u4E5F\u7B97\u6551\u6211\u4E00\u547D\uFF0C\u662F\u8981\u8BA8\u4F10\u9B54\u738B\u662F\u5427\uFF0C\u8FD9\u4E2A\u7ED9\u4F60"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6559\u5802\u662F\u6211\u4ECE\u5C0F\u957F\u5927\u7684\u5730\u65B9\uFF0C\u53EF\u81EA\u4ECE\u8FD9\u7FA4\u9B54\u7269\u5165\u4FB5\uFF0C\u6CA1\u4E00\u5929\u8FC7\u7684\u5B89\u751F\u65E5\u5B50"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6211\u60F3\u548C\u4F60\u4E00\u8D77\u53BB\u51FB\u8D25\u9B54\u738B\uFF0C\u522B\u770B\u6211\u8FD9\u6837\uFF0C\u6211\u4E5F\u7B97\u6559\u5802\u91CC\u7684\u9AD8\u7EA7\u7267\u5E08\uFF0C\u63D0\u4F9B\u4E00\u4E9B\u6CBB\u7597\u548C\u6218\u6597\u5E2E\u52A9\u8FD8\u662F\u7EF0\u7EF0\u6709\u4F59\u7684"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\uFF08\u6B64\u65F6\u6000\u91CC\u7684\u949F\u8868\u6CDB\u8D77\u5149\u8F89\uFF09\u53EE\uFF5E\u951A\u5B9A\u6210\u529F\uFF01"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: -1
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: "\uFF08\u58F0\u97F3\u8C8C\u4F3C\u4ECE\u5F88\u8FDC\u7684\u5730\u65B9\u98D8\u6765\uFF09\u8FD9\u4E0B\uFF0C\u9B54\u738B\u4E5F\u6CA1\u6CD5\u8F7B\u6613\u6539\u5199\u65F6\u95F4\u4E86\uFF0C\u4E4B\u540E\u7684\u4E8B\u60C5\u4F60\u5C31\u6162\u6162\u81EA\u5DF1\u63A2\u7D22\u5427\uFF0C\u52A0\u6CB9\u5440\uFF01"
    onEnd: 5
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
