  dialogues:
  - dialogueType: 1
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u6211\u5DF4\u6797\uFF0C\u4F1F\u5927\u7684\u77EE\u4EBA\u65CF\uFF0C\u4E5F\u613F\u610F\u4E0E\u4F60\u4E00\u540C"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u54FC\u54FC\uFF0C\u8FD9\u6B21\u53C8\u52C9\u5F3A\u80DC\u8FC7\u6211\u4E86\u5417\uFF0C\u4F46\u662F\u8FD9\u4E0D\u8FC7\u53EA\u4F1A\u8BA9\u4F60\u9677\u5165\u66F4\u591A\u7684\u8F6E\u56DE\u4E4B\u4E2D\uFF0C\u4F60\u8DDF\u6839\u672C\u6CA1\u6CD5\u638C\u63E1\u8FD9\u4EFD\u80DC\u5229\uFF0C\u6E38\u620F\u7684\u7ED3\u675F\u6743\u5728\u6211\u624B\u4E0A\uFF0C\u8FD9\u53EA\u4E0D\u8FC7\u662F\u8BA9\u6211\u80FD\u66F4\u4E45\u7684\u6B23\u8D4F\u4F60\u7684\u6323\u624E\u800C\u5DF2\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: "\u4F60\u5DF2\u7ECF\u4F5C\u6076\u592A\u4E45\u4E86\uFF0C\u5C31\u5728\u8FD9\u91CC\uFF0C\u5C31\u5728\u6B64\u65F6\uFF0C\u6211\u4F1A\u5C06\u4F60\u7684\u5931\u8D25\uFF0C\u951A\u5B9A\u5728\u65F6\u95F4\u957F\u6CB3\u4E4B\u4E2D\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: " (\u6000\u8868\u53D1\u5149,\u5F00\u59CB\u951A\u5B9A\u8FD9\u4E00\u523B\u7684\u65F6\u95F4)"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u4EC0\u4E48\uFF1F\u600E\u4E48\u4F1A\uFF0C\u6211\u65E0\u654C\u7684\u56DE\u6EAF\u4E4B\u529B\u7ADF\u7136\u5F00\u59CB\u51CF\u5F31\u4E86\uFF0C\u4F60\u7ADF\u7136\u80FD\u7528\u51FA\u201C\u771F\u5B9E\u5386\u53F2\u201D\u7684\u529B\u91CF\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: "\u4F60\u56DB\u5904\u7834\u574F\u7684\u65E5\u5B50\u5230\u5934\u4E86\uFF0C\u8FD9\u6B21\u6211\u5C06\u5F7B\u5E95\u7684\u6D88\u706D\u4F60\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u7B49\u7B49\u7B49\u7B49\uFF0C\u6211\u89C9\u5F97\u6211\u4EEC\u53EF\u4EE5\u8C08\u4E00\u8C08\uFF0C\u6211\u53EF\u4EE5\u64A4\u519B\uFF0C\u53EF\u4EE5\u8865\u507F\u4F60\uFF0C\u6211\u6240\u6709\u7684\u5B9D\u7269\u90FD\u53EF\u4EE5\u7ED9\u4F60\uFF0C\u6211\u53EF\u4EE5\u628A\u5927\u519B\u90FD...."
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: "\u5E9F\u8BDD\u771F\u591A  \u4E00\u68CD\u6253\u6B7B"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 1
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: -1
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u5E9F\u8BDD\u771F\u591A  \u4E00\u68CD\u6253\u6B7B"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u7EC8\u4E8E\u7ED3\u675F\u4E86\uFF0C\u771F\u662F\u7D2F\u762B\u6211\u4E86"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\u662F\u5417\uFF0C\u53EF\u662F\u5728\u6211\u770B\u6765\u548C\u6218\u6597\u65F6\u5019\u5DEE\u4E0D\u591A\u9AD8"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: "\u5B89\u514B\u4F60\u8FD8\u6709\u4EC0\u4E48\u6253\u7B97\u5417"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 0
    text: "\u542C\u8BF4\u522B\u7684\u6751\u5E84\u4E5F\u90FD\u88AB\u8FD9\u79CD\u9B54\u738B\u88AD\u51FB\u4E86\uFF0C\u6211\u6253\u7B97\u6E38\u5386\u4E16\u754C\u5E2E\u52A9\u4ED6\u4EBA"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: "\u4E0D\u9519\u7684\u60F3\u6CD5\uFF0C\u6211\u613F\u4E0E\u4F60\u4E00\u540C\u884C\u81F3\u4E16\u754C\u5C3D\u5934"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6211\u5DF4\u6797\uFF0C\u4F1F\u5927\u7684\u77EE\u4EBA\u65CF\uFF0C\u4E5F\u613F\u610F\u4E0E\u4F60\u4E00\u540C"
