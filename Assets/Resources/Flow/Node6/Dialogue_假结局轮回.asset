  dialogues:
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6840\u6840\u6840\uFF0C\u8FD9\u6B21\u4F60\u7ADF\u7136\u80FD\u53D1\u73B0\u6211\u7684\u5B58\u5728\u4E86\uFF0C\u90A3\u4E09\u4E2A\u65E0\u804A\u7684\u5BB6\u4F19\u7ED9\u4E86\u4F60\u4EC0\u4E48\u4E1C\u897F\u5427\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: " (\u611F\u89C9\u5230\u5934\u75DB\u6B32\u88C2\uFF0C\u4F3C\u4E4E\u66FE\u7ECF\u89C1\u5230\u8FC7\u8FD9\u4E2A\u573A\u666F)
      \u554A...... \u4F60\u662F\u8C01\uFF1F\u6211\u7684\u961F\u53CB\u5462\uFF1F"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u5728\u610F\u90A3\u79CD\u6CA1\u6709\u201C\u4EFD\u91CF\u201D\u7684\u5C0F\u89D2\u8272\u5E72\u561B\uFF0C\u65E2\u7136\u4F60\u80FD\u53D1\u73B0\u6211\u4E86\uFF0C\u4E5F\u5C31\u4EE3\u8868\u6211\u80FD\u591F\u5E2E\u4F60\u8FDB\u884C\u4E00\u4E9B\u201C\u6539\u53D8\u201D"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u4F5C\u4E3A\u7279\u6B8A\u7684\u5B58\u5728\uFF0C\u4F60\u771F\u7684\u8981\u548C\u90A3\u4E9B\u877C\u8681\u5206\u4EAB\u8363\u8000\u4E0E\u540D\u8A89\u5417\uFF0C\u6CA1\u60F3\u8FC7\u201C\u72EC\u81EA\u201D\u5360\u636E\u51FB\u8D25\u9B54\u738B\u7684\u529F\u7EE9\u5417"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\uFF08\u75DB\u82E6\u5730\u6342\u7740\u5934\uFF09\u4E0D\uFF0C\u8FD9\u4F3C\u4E4E......"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6765\u5427\uFF0C\u6765\u9009\u62E9\u62E5\u62B1\u6DF7\u6C8C\u5427\uFF0C\u4F60\u5C06\u83B7\u5F97\u5C5E\u4E8E\u4F60\u7684\u81EA\u7531\uFF0C\u8FD9\u4EFD\u529B\u91CF\u751A\u81F3\u53EF\u4EE5\u5E2E\u4F60\u8F7B\u677E\u51FB\u8D25\u9B54\u738B"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\uFF08\u63D0\u5230\u9B54\u738B\u7684\u65F6\u5019\u4F3C\u4E4E\u8F7B\u8511\u7684\u7B11\u4E86\u4E0B\uFF09\u5230\u65F6\u5019\u56DE\u6EAF\u7684\u529B\u91CF\u4E5F\u4E0D\u8FC7\u662F\u4F60\u7684\u624B\u4E0B\u8D25\u5C06\u7F62\u4E86\uFF0C\u6765\u505A\u9009\u62E9\u5427\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\uFF08\u653E\u4E0B\u624B\uFF0C\u8868\u60C5\u9010\u6E10\u575A\u5B9A\uFF09"
    onEnd: 3
    Battle: {fileID: 0}
    Branch: {fileID: 11400000, guid: 8a832d68801e5f942ac1f42acaf93471, type: 2}
