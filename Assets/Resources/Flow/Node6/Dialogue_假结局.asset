    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u6211\u7684\u8FD9\u4EFD\u6DF7\u6C8C\u529B\u91CF\u6839\u672C\u4E0D\u662F\u4F60\u80FD\u60F3\u8C61\u7684\uFF0C\u4F60\u4E0D\u8FC7\u662F\u4E2A\u7A83\u636E\u4E86\u4E9B\u5FAE\u6DF7\u6C8C\u7684\u5C0F\u5077\u7F62\u4E86\uFF0C\u4F60\u4EE5\u4E3A\u6211\u8FD9\u4E00\u8DEF\u72EC\u81EA\u8D70\u6765\u5230\u5E95\u7ECF\u5386\u4E86\u4EC0\u4E48\uFF0C\u6211\u72EC\u81EA\uFF0C\uFF0C\u6211\u72EC\u81EA\uFF0C\uFF0C"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u6211\u662F\u72EC\u81EA\u4E00\u4EBA\u8E0F\u4E0A\u8DEF\u9014\u7684\u5417\uFF0C\u6211\u597D\u60F3\u5FD8\u8BB0\u4E86\u51B3\u4E0D\u80FD\u5FD8\u8BB0\u7684\u4E8B\uFF0C\u6211\u8FD9\u5230\u5E95\u662F\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u54C8\u54C8\u54C8\u54C8\u54C8\u54C8\u54C8\uFF0C\u4E3A\u4E86\u80DC\u8FC7\u6211\u8FDE\u540C\u4F34\u90FD\u62B9\u53BB\u4E86\u5417\uFF0C\u4F60\u7684\u8FD9\u4EFD\u65E0\u60C5\u6B8B\u5FCD\u6211\u8BA4\u53EF\u4E86\uFF0C\u4F60\u5C31\u5E26\u7740\u51FB\u8D25\u6211\u7684\u8363\u8000\u5B64\u72EC\u7684\u6D3B\u4E0B\u53BB\u5427\u3002\u7EA2\u7EA2\u706B\u706B\u604D\u604D\u60DA\u60DA\u54C8\u54C8\u54C8\u54C8"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\u4E0D\u3002\u3002\u3002\u3002\u3002\u3002"
    onEnd: 0
