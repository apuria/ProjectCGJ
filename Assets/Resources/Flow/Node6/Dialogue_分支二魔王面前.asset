  dialogues:
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u771F\u662F\u4E4F\u5473\u81F3\u6781\u7684\u8F6E\u56DE\u554A\uFF0C\u4F60\u8FD9\u5C0F\u9B3C\u5230\u5E95\u8981\u6323\u624E\u591A\u5C11\u6B21\u624D\u80FD\u5FC3\u7518\u60C5\u613F\u7684\u653E\u5F03\u5462\uFF0C\u4F60\u7684\u653B\u51FB\uFF0C\u6280\u80FD\uFF0C\u9053\u5177\uFF0C\u4F19\u4F34\uFF0C\u751A\u81F3\u662F\u9677\u5165\u7EDD\u5883\u65F6\u7684\u7206\u53D1\uFF0C\u6211\u5DF2\u7ECF\u5168\u90E8\u638C\u63E1\u4E86\uFF0C\u5C31\u8FDE\u4F60\u6BCF\u4E00\u53E5\u65E0\u804A\u7684\u53E3\u53F7\u6211\u90FD\u542C\u817B\u4E86\u3002\u4F60\u60F3\u4EC5\u51ED\u4F60\u90A3\u6E23\u6ED3\u4E00\u6837\u7684\u201C\u4EFD\u91CF\u201D\u6765\u8DE8\u8D8A\u6211\u56DE\u6EAF\u7684\u957F\u6CB3\u5417\uFF1F"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u5C31\u51ED\u4F60\u7684\u8089\u4F53\uFF0C\u7CBE\u795E\u548C\u7075\u9B42\uFF0C\u5728\u6211\u7684\u529B\u91CF\u9762\u524D\u4E0D\u8FC7\u662F\u4E2A\u877C\u8681\u7F62\u4E86\uFF0C\u770B\u5728\u4F60\u6323\u624E\u4E86\u8FD9\u4E48\u591A\u6B21\u7684\u4EFD\u4E0A\uFF0C\u6211\u5141\u8BB8\u4F60\u6295\u5165\u6211\u7684\u9EBE\u4E0B\u5F53\u4E2A\u9B54\u65CF\u6765\u4E3A\u6211\u6548\u529B\uFF0C\u4E0D\u7136\u7684\u8BDD\uFF0C\u8FD9\u4E00\u6B21\u6211\u4F1A\u5C06\u4F60\u7684\u5934\u9885\u653E\u5728\u6211\u7684\u738B\u5EA7\u4E0B\u5F53\u505A\u57AB\u811A\u77F3\uFF0C\u8FD9\u5C06\u662F\u4F60\u7684\u4E07\u52AB\u4E0D\u590D\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: .......
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\uFF08\u867D\u7136\u81EA\u5DF1\u6CA1\u6709\u4E4B\u524D\u56DE\u6EAF\u7684\u8BB0\u5FC6\uFF0C\u4F46\u662F\u4ED6\u7684\u6BCF\u4E00\u4E2A\u7EC6\u80DE\uFF0C\u6BCF\u4E00\u7247\u7075\u9B42\uFF0C\u90FD\u5728\u50AC\u4FC3\u81EA\u5DF1\u8BF4\u51FA\u4E00\u53E5\u8BDD\uFF09"
    onEnd: 0
