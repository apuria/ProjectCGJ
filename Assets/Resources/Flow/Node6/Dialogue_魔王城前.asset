  dialogues:
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u76EE\u7684\u5730\u5FEB\u5230\u4E86\uFF0C\u7684\u786E\u662F\u80FD\u611F\u53D7\u5230\u4E00\u80A1\u5F3A\u5927\u7684\u9B54\u529B\u76D8\u8E1E\u5728\u57CE\u5185\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6CA1\u9519\uFF0C\u90A3\u6B63\u662F\u8FD9\u6B21\u9B54\u707E\u7684\u6E90\u5934\uFF0C\u9B54\u2192\u738B\u2197"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 2
    talkingSpeaker: 1
    text: "\uFF08\u6C89\u9ED8\u7684\u4F4E\u4E0B\u5934\uFF0C\u6574\u7406\u8D77\u4E86\u6B66\u5668\uFF09"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u4E0D\u5BF9\uFF0C\u4E0D\u6B62\u4E00\u4E2A\uFF0C\u8FD8\u6709\u53E6\u4E00\u4E2A\u5947\u602A\u7684\u6C14\u606F\u5728.....\u5C31\u5728\u6211\u4EEC\u9644\u8FD1\uFF0C\u5DF4\u6797\uFF0C\u8389\u6069\uFF0C\u6CE8\u610F\u6212....!!!"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\uFF08\u5B89\u514B\u8F6C\u5934\u5374\u53D1\u73B0\u81EA\u5DF1\u7684\u4E24\u4E2A\u961F\u53CB\u5DF2\u7ECF\u6D88\u5931\u7684\u65E0\u5F71\u65E0\u8E2A\u4E86\uFF09"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: -1
    talkingSpeaker: 0
    text: "\u600E\u4E48\u56DE\u4E8B\uFF0C\u96BE\u9053\u662F\u9B54\u738B\u519B\u7684\u6CD5\u9635\u9694\u5F00\u4E86\u6211\u4EEC\uFF1F\u5929\u751F\u90AA\u6076\u7684\u9B54\u65CF\uFF0C\u6211\u8FD9\u5C31..."
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u6840\u6840\u6840\uFF0C\u8FD9\u6B21\u4F60\u7ADF\u7136\u80FD\u53D1\u73B0\u6211\u7684\u5B58\u5728\u4E86\uFF0C\u90A3\u4E09\u4E2A\u65E0\u804A\u7684\u5BB6\u4F19\u7ED9\u4E86\u4F60\u4EC0\u4E48\u4E1C\u897F\u5427\u3002"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: "\u4F60\u662F\u4EC0\u4E48\u4EBA\uFF0C\u6211\u961F\u53CB\u7684\u6D88\u5931\u662F\u8DDF\u4F60\u6709\u5173\u7CFB\uFF1F"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u5728\u610F\u90A3\u79CD\u6CA1\u6709\u201C\u4EFD\u91CF\u201D\u7684\u5C0F\u89D2\u8272\u5E72\u561B\uFF0C\u65E2\u7136\u4F60\u80FD\u53D1\u73B0\u6211\u4E86\uFF0C\u4E5F\u5C31\u4EE3\u8868\u6211\u80FD\u591F\u5E2E\u4F60\u8FDB\u884C\u4E00\u4E9B\u201C\u6539\u53D8\u201D"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\u4F5C\u4E3A\u7279\u6B8A\u7684\u5B58\u5728\uFF0C\u4F60\u771F\u7684\u8981\u548C\u90A3\u4E9B\u877C\u8681\u5206\u4EAB\u8363\u8000\u4E0E\u540D\u8A89\u5417\uFF0C\u6CA1\u60F3\u8FC7\u201C\u72EC\u81EA\u201D\u5360\u636E\u51FB\u8D25\u9B54\u738B\u7684\u529F\u7EE9\u5417"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 0
    text: "\u6211\u53EA\u60F3\u77E5\u9053\u6211\u7684\u961F\u53CB\u5230\u5E95\u5728..."
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\uFF08\u7C97\u66B4\u7684\u6253\u65AD\uFF09\u6765\u5427\uFF0C\u6765\u9009\u62E9\u62E5\u62B1\u6DF7\u6C8C\u5427\uFF0C\u4F60\u5C06\u83B7\u5F97\u5C5E\u4E8E\u4F60\u7684\u81EA\u7531\uFF0C\u8FD9\u4EFD\u529B\u91CF\u751A\u81F3\u53EF\u4EE5\u5E2E\u4F60\u8F7B\u677E\u51FB\u8D25\u9B54\u738B"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 3
    talkingSpeaker: 1
    text: "\uFF08\u63D0\u5230\u9B54\u738B\u7684\u65F6\u5019\u4F3C\u4E4E\u8F7B\u8511\u7684\u7B11\u4E86\u4E0B\uFF09\u5230\u65F6\u5019\u56DE\u6EAF\u7684\u529B\u91CF\u4E5F\u4E0D\u8FC7\u662F\u4F60\u7684\u624B\u4E0B\u8D25\u5C06\u7F62\u4E86\uFF0C\u6765\u505A\u9009\u62E9\u5427\u3002"
    onEnd: 3
    Battle: {fileID: 0}
    Branch: {fileID: 11400000, guid: 0af6fd9be1b8db342ac9953502451e49, type: 2}
    NextLog: {fileID: 0}
    End: {fileID: 0}
