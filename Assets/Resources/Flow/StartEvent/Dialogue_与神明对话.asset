  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\u2026\u2026\u7B49\u4E0B\uFF0C\u8981\u5410\u69FD\u7684\u70B9\u6709\u70B9\u591A"
