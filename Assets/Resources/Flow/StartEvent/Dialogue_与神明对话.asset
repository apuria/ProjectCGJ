    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u5443\uFF0C\u5BF9\u4E0D\u8D77\uFF0C\u6211\u592A\u5FD9\u4E86\uFF0C\u5728\u4F60\u88AB\u51FB\u8D25\u7684\u65F6\u5019\u91CD\u6765\u7684\u8FD9\u4EF6\u4E8B\u592A\u9EBB\u70E6\u4E86\uFF0C\u73B0\u5728\u6211\u7684\u529B\u91CF\u4E5F\u4E0D\u592A\u591F\u4E86"
