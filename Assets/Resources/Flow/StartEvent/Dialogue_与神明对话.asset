    showDialogueBox: 0
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u6211\u6765\u89E3\u91CA\u4E00\u4E0B\u5427\uFF0C\u4F60\u73B0\u5728\u662F\u8981\u53BB\u8BA8\u4F10\u9B54\u738B\u7684\u8DEF\u4E0A\u5BF9\u5427\uFF1F"
