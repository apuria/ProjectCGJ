    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u54CE\u5440\uFF0C\u603B\u800C\u8A00\u4E4B\uFF0C\u6211\u662F\u8FD9\u4E2A\u4E16\u754C\u7684\u795E\u660E\uFF0C\u8D1F\u8D23\u7EF4\u62A4\u8FD9\u4E2A\u4E16\u754C\u7684\u7A33\u5B9A\uFF0C\u5DE5\u4F5C\u5185\u5BB9\u5927\u6982\u662F\u5E2E\u4F60\u6210\u529F\u51FB\u8D25\u9B54\u738B"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 1
    text: "\u4E0D\u8FC7\u9B54\u738B\u6BCF\u6B21\u5728\u4F60\u51FB\u8D25\u4ED6\u6216\u8005\u4E4B\u540E\uFF0C\u90FD\u4F1A\u94BB\u67D0\u4E9Bbug\uFF0C\u6765\u6270\u4E71\u8FD9\u4E2A\u4E16\u754C\u7684\u65F6\u7A7A\uFF0C\u5BFC\u81F4\u4F60\u5DF2\u7ECF\u91CD\u6765\u4E86\u6210\u767E\u4E0A\u5343\u6B21\u8FD9\u6837\u7684\u5267\u60C5\u4E86"
    onEnd: 0
    Battle: {fileID: 0}
    Branch: {fileID: 0}
    NextLog: {fileID: 0}
    End: {fileID: 0}
  - dialogueType: 0
    cgImage: {fileID: 0}
    showDialogueBox: 1
    leftSpeakerIndex: 0
    rightSpeakerIndex: 1
    talkingSpeaker: 0
    text: "\u6240\u4EE5\uFF0C\u4F60\u662F\u6765\u5E2E\u6211\u51FB\u8D25\u9B54\u738B\u7684\uFF1F"
