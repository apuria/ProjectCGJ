    showDialogueBox: 0
    leftSpeakerIndex: 1
    rightSpeakerIndex: 2
    talkingSpeaker: 0
    text: "\u5C0F\u59D1\u5A18\u8EAB\u624B\u4E0D\u9519\u5440\uFF0C\u600E\u4E48\u6765\u5230\u8FD9\u4E48\u5371\u9669\u7684\u5730\u65B9"
    onEnd: 0
