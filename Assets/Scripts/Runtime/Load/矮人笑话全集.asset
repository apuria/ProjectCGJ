  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 56de9dbadc1611b49a310c3bab1eb63d, type: 3}
  m_Name: "\u77EE\u4EBA\u7B11\u8BDD\u5168\u96C6"
  m_EditorClassIdentifier: 
  texts:
  - text: "\u77EE\u4EBA\u4EEC\u8D34\u51FA\u4E86\u4E00\u6761\u516C\u544A\u7981\u6B62\u8BB2\u77EE\u4EBA\u7B11\u8BDD\uFF0C\u4F46\u5176\u5B83\u79CD\u65CF\u6CA1\u6709\u770B\u5230"
  - text: "\u4E3A\u4EC0\u4E48\u77EE\u4EBA\u89C9\u5F97\u4EBA\u7C7B\u5F88\u6709\u793C\u8C8C\uFF1F\n\u56E0\u4E3A\u6BCF\u6B21\u4EBA\u7C7B\u6765\u62DC\u8BBF\u77EE\u4EBA\uFF0C\u5728\u8FDB\u95E8\u65F6\u90FD\u4F1A\u5F2F\u8170\u3002"
  - text: "\u6210\u5409\u601D\u6C57\u7A7F\u8D8A\u5F02\u4E16\u754C\u540E\uFF0C\u7531\u4E8E\u8FD8\u575A\u5B88\u7740\u4F4E\u4E8E\u8F66\u8F6E\u8005\u4E0D\u6740\u7684\u7406\u5FF5\uFF0C\u88AB\u77EE\u4EBA\u8BA4\u4E3A\u662F\u4E0D\u6740\u4FD8\u7684\u8D24\u738B"
  - text: "\u201C\u6709\u4EC0\u4E48\u53EF\u4EE5\u8BA9\u6211\u9752\u53F2\u7559\u540D\u7684\u597D\u529E\u6CD5\u5417\uFF1F\u201D\n\u201C\u8BA8\u4F101\u4E07\u6761\u6076\u9F99\u3001\u953B\u9020\u7EDD\u4E16\u4E4B\u5251\u3001\u5EFA\u9020\u575A\u4E0D\u53EF\u6467\u7684\u57CE\u6C60...\u201D\n\u201C\u6765\u51E0\u4E2A\u7B80\u5355\u70B9\u7684\u201D\n\u201C\u5199\u4E2A\u77EE\u4EBA\u7B11\u8BDD\uFF0C\u5982\u679C\u4F60\u4E0D\u4ECB\u610F\u8FD9\u672C\u2018\u9752\u53F2\u2019\u662F\u4EC7\u6068\u4E4B\u4E66\u201D"
  - text: "\u4EE4\u4EBA\u610F\u5916\u7684\u662F\uFF0C\u77EE\u4EBA\u7684\u8111\u79D1\u533B\u5B66\u7ECF\u9A8C\u5F88\u4E30\u5BCC\uFF0C\u8FD9\u662F\u56E0\u4E3A\u6765\u77EE\u4EBA\u57CE\u5E02\u65C5\u6E38\u7684\u5176\u4ED6\u79CD\u65CF\u7ECF\u5E38\u4F1A\u88AB\u95E8\u6846\u649E\u5230\u5934"
  - text: "\u4E3A\u4EC0\u4E48\u77EE\u4EBA\u89C9\u5F97\u4EBA\u7C7B\u5F88\u6709\u793C\u8C8C\uFF1F\n\u56E0\u4E3A\u6BCF\u6B21\u4EBA\u7C7B\u6765\u62DC\u8BBF\u77EE\u4EBA\uFF0C\u5728\u8FDB\u95E8\u65F6\u90FD\u4F1A\u5F2F\u8170\u3002"
